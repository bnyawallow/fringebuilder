# Daraja API Credentials (M-PESA)
MPESA_ENVIRONMENT=sandbox # use 'sandbox' or 'production'
MPESA_CONSUMER_KEY=your_consumer_key
MPESA_CONSUMER_SECRET=your_consumer_secret
MPESA_PASSKEY=your_passkey
MPESA_SHORTCODE=your_shortcode # e.g. 174379 (sandbox paybill)

# The base URL of this application to receive M-PESA STK callbacks
# Example: https://ais-dev-xxxxxxxxxxxx.europe-west2.run.app
APP_BASE_URL=
